generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String    @map("password_hash")
  createdAt    DateTime  @default(now()) @map("created_at")

  income     Income[]
  expense    Expense[]
  lend       Lend[]
  borrow     Borrow[]
  budgets    Budget[]
  contacts   Contact[]
  categories Category[]
  mediums    Medium[]

  @@map("users")
}

model Contact {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  phone     String   @default("")
  type      String   @default("person") // person | organization
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@map("contacts")
}

model Category {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  forType   String   @map("for_type") // income | expense | both
  color     String   @default("#6b7280")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name, forType])
  @@index([userId, forType])
  @@map("categories")
}

model Medium {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@map("mediums")
}

model Income {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  amount     Float
  date       String
  from       String   @default("")
  fromPhone  String   @default("") @map("from_phone")
  medium     String
  category   String
  reason     String   @default("")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("income")
}

model Expense {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  amount    Float
  date      String
  payTo     String   @default("") @map("pay_to")
  payToPhone String  @default("") @map("pay_to_phone")
  medium    String
  category  String
  reason    String   @default("")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("expense")
}

model Lend {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  amount    Float
  date      String
  to        String
  toPhone   String   @default("") @map("to_phone")
  medium    String
  dueDate   String   @default("") @map("due_date")
  reason    String   @default("")
  paid      Boolean  @default(false)
  paidDate  String?  @map("paid_date")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("lend")
}

model Borrow {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  amount    Float
  date      String
  from      String
  fromPhone String   @default("") @map("from_phone")
  medium    String
  dueDate   String   @default("") @map("due_date")
  reason    String   @default("")
  paid      Boolean  @default(false)
  paidDate  String?  @map("paid_date")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("borrow")
}

model Budget {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  month     String
  category  String
  amount    Float    @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, category])
  @@index([userId, month])
  @@map("budget")
}
